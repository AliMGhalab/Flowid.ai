# ─── Firebase ────────────────────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
# Enable Authentication (Email/Password + Google) and Firestore Database
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Chutes AI (DeepSeek V3) ─────────────────────────────────────────────────
# Get your API key at https://chutes.ai
CHUTES_API_KEY=

# ─── Tavily Search API (live supplier pricing) ────────────────────────────────
# Get a free API key at https://app.tavily.com
# Used to search predefined Malaysian supplier websites for real-time prices.
# Without this key the "Check Live Prices" button will silently return no results.
TAVILY_API_KEY=

