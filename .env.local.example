# ═══════════════════════════════════════════════════════════════════════════
# Flowid.ai — Environment Variables
# Copy this file to `.env.local` and fill in the values below.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Firebase (required) ─────────────────────────────────────────────────────
# 1. Create a project at https://console.firebase.google.com
# 2. Enable Authentication: Email/Password + Google providers
# 3. Enable Firestore Database
# 4. Add your deployment domain to Authentication > Settings > Authorized domains
# 5. Add to Google Cloud Console > APIs & Services > OAuth client:
#    - Authorised JavaScript origins: https://your-domain.com
#    - Authorised redirect URIs: https://your-domain.com/__/auth/handler
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── AI Providers ────────────────────────────────────────────────────────────
# At least ONE provider key is required. Provided in priority order; the chain
# automatically falls back if a provider rate-limits, errors, or times out.

# CEREBRAS — primary provider (Qwen 235B, 30 RPM free tier, blazing fast)
# Get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# MISTRAL — fallback provider (Mistral Medium, native JSON mode)
# Get a key at https://console.mistral.ai
MISTRAL_API_KEY=

# SAMBANOVA — second fallback (Llama 3.3 70B, ~20 RPM)
# Get a key at https://cloud.sambanova.ai
SAMBANOVA_API_KEY=

# GEMINI — optional secondary (Gemini 2.0 Flash, 1500 RPD free)
# Get a key at https://aistudio.google.com
GEMINI_API_KEY=

# CHUTES — optional (DeepSeek V3, paid)
# Get a key at https://chutes.ai
CHUTES_API_KEY=

# ─── Tavily Search (optional — live supplier price verification) ─────────────
# Free key at https://app.tavily.com
# Without this, the "Check Live Prices" button returns no results silently.
TAVILY_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
